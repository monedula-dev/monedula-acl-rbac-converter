# Default: let git handle text/binary detection.
* text=auto

# Shell scripts must stay LF on all platforms — golden-file tests
# compare them byte-for-byte against generator output, which always
# emits LF.
*.sh text eol=lf

# YAML and JSON config files: LF everywhere. CI YAML in particular is
# parsed by GitHub Actions on Linux runners regardless of where it was
# authored.
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Go source: LF (matches gofmt and the upstream toolchain).
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# Schemas embedded by //go:embed: LF (otherwise `git diff --exit-code`
# in CI after sync-schemas would flip on Windows).
schemas/* text eol=lf
